{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capability for XKG Desktop",
  "windows": ["capture", "settings"],
  "permissions": [
    "core:default",
    "core:window:default",
    "core:window:allow-show",
    "core:window:allow-hide",
    "core:window:allow-set-focus",
    "core:webview:default",
    "core:event:default",
    "autostart:default"
  ]
}
